# Express API base URL.
# iOS Simulator: http://localhost:4000 works as-is.
# Physical device (Expo Go): use your Mac's LAN IP, e.g. http://192.168.1.20:4000
# Android emulator: http://10.0.2.2:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_WEB_URL=https://app.betterpomo.com

# Same Supabase project as betterpomo-webapp (NEXT_PUBLIC_* equivalents).
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
